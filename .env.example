# General
PROJECT_NAME=genesis
PROJECT_ROOT=/projects/genesis
APP_DOMAIN=shellr.net
DMA_DOMAIN=dma.shellr.net
TIMEZONE=Europe/Berlin

# Container registry
REGISTRY=ghcr.io
REGISTRY_NAMESPACE=your-github-user-or-org
APP_IMAGE=genesis-app
DMA_IMAGE=genesis-dma

# PostgreSQL
POSTGRES_DB=genesis
POSTGRES_USER=genesis
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Monitoring
GRAFANA_DOMAIN=grafana.shellr.net
PROMETHEUS_RETENTION=7d
LOKI_RETENTION=7d

# Backup
BACKUP_RETENTION_DAYS=7
RESTIC_REPOSITORY=replace-me
RESTIC_PASSWORD=replace-me
